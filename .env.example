# Masters Marketing Agency - Environment Variables
# Copy this file to .env.local and fill in your values

# Admin Portal Password
ADMIN_PASSWORD=your-secure-admin-password

# Anthropic API Key (for AI social media content generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend API Key (for sending review request emails)
RESEND_API_KEY=re_...

# Business Email (for reply-to on review requests)
BUSINESS_EMAIL=info@mastersmarketingagency.com

# Google Review URL (direct link to leave a review)
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_PLACE_ID/review
